{
  "name": "@opencode-trace/core",
  "version": "0.0.2",
  "type": "module",
  "description": "Core functionality for opencode-trace",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./state": {
      "import": "./dist/state/index.js",
      "types": "./dist/state/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "sql.js": "^1.14.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.11",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aixmoyu/opencode-trace.git",
    "directory": "packages/core"
  },
  "keywords": [
    "opencode",
    "trace",
    "core"
  ],
  "license": "MIT"
}