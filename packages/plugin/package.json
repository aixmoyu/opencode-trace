{
  "name": "@opencode-trace/plugin",
  "version": "0.0.7",
  "type": "module",
  "description": "OpenCode plugin for trace recording",
  "main": "./dist/trace.js",
  "types": "./dist/trace.d.ts",
  "exports": {
    ".": {
      "import": "./dist/trace.js",
      "types": "./dist/trace.d.ts"
    },
    "./tracer": {
      "import": "./dist/tracer.js",
      "types": "./dist/tracer.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "debug:plugin:create": "node ../../scripts/test-plugin.mjs create",
    "debug:plugin:remove": "node ../../scripts/test-plugin.mjs remove",
    "test:watch": "vitest watch",
    "clean": "node ../../scripts/clean.mjs"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.22",
    "@opencode-ai/sdk": "^1.14.41",
    "@opencode-trace/core": "0.0.7"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aixmoyu/opencode-trace.git",
    "directory": "packages/plugin"
  },
  "keywords": [
    "opencode",
    "trace",
    "plugin"
  ],
  "license": "MIT"
}