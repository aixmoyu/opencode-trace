{
  "name": "@opencode-trace/viewer",
  "version": "0.0.2",
  "type": "module",
  "description": "Web viewer for opencode-trace",
  "bin": {
    "opencode-trace-viewer": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run build:frontend",
    "build:frontend": "vite build --config src/frontend/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@opencode-trace/core": "0.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.0",
    "fastify": "^5.8.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aixmoyu/opencode-trace.git",
    "directory": "packages/viewer"
  },
  "keywords": [
    "opencode",
    "trace",
    "viewer"
  ],
  "license": "MIT"
}