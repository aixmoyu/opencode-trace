{
  "name": "opencode-trace-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Monorepo for opencode-trace packages",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:frontend": "turbo run build:frontend",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "node scripts/clean.mjs && turbo run clean",
    "cli": "node packages/cli/dist/index.js",
    "viewer": "node packages/viewer/dist/cli.js",
    "dev": "concurrently \"npm run dev:watch\" \"npm run dev:serve\"",
    "dev:watch": "tsc -b --watch",
    "dev:serve": "nodemon --watch packages/viewer/dist --exec 'node packages/viewer/dist/cli.js --no-open'",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "version": "changeset version",
    "publish": "changeset publish",
    "release": "npm run build && npm run publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.3",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "opencode",
    "trace",
    "monorepo"
  ],
  "license": "MIT"
}
